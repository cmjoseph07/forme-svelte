{
  "name": "@formepdf/svelte",
  "version": "0.10.4",
  "description": "Svelte-to-JSON serializer for Forme PDF engine",
  "type": "module",
  "main": "./dist/index.js",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/preview/index.d.ts",
      "default": "./dist/preview/index.js"
    }
  },
  "scripts": {
    "embed-preview": "node scripts/embed-preview-html.mjs",
    "build": "npm run embed-preview && svelte-package -i src -o dist",
    "check": "npm run embed-preview && svelte-check --tsconfig ./tsconfig.json",
    "test": "npm run embed-preview && vitest run",
    "test:watch": "npm run embed-preview && vitest"
  },
  "dependencies": {
    "@formepdf/shared": "0.10.4",
    "parse5": "^7.2.1"
  },
  "peerDependencies": {
    "@formepdf/core": "^0.10.4",
    "svelte": "^5.30.0"
  },
  "peerDependenciesMeta": {
    "@formepdf/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@formepdf/core": "0.10.4",
    "@formepdf/react": "0.10.4",
    "@formepdf/tailwind": "0.10.4",
    "@sveltejs/package": "^2.3.10",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "svelte": "^5.30.0",
    "svelte-check": "^4.7.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/formepdf/forme",
    "directory": "packages/svelte"
  }
}
