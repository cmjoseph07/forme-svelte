{
  "name": "@formepdf/core",
  "version": "0.10.1",
  "description": "WASM-powered PDF rendering engine for Forme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "worker": {
        "types": "./dist/worker.d.ts",
        "import": "./dist/worker.js"
      },
      "edge-light": {
        "types": "./dist/worker.d.ts",
        "import": "./dist/worker.js"
      },
      "deno": {
        "types": "./dist/worker.d.ts",
        "import": "./dist/worker.js"
      },
      "react-native": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js"
      },
      "browser": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    },
    "./pkg/forme.js": {
      "types": "./pkg/forme.d.ts",
      "import": "./pkg/forme.js"
    },
    "./pkg/forme_bg.wasm": "./pkg/forme_bg.wasm",
    "./pkg-web/forme.js": {
      "types": "./pkg-web/forme.d.ts",
      "import": "./pkg-web/forme.js"
    },
    "./pkg-web/forme_bg.wasm": "./pkg-web/forme_bg.wasm"
  },
  "scripts": {
    "build:wasm": "./build.sh && rm -f pkg/.gitignore pkg-web/.gitignore pkg-node/.gitignore",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run build:ts",
    "test": "vitest run",
    "test:workers": "vitest run --config vitest.config.workers.ts",
    "prepublishOnly": "npm run build && ./scripts/assert-tarball.sh"
  },
  "dependencies": {
    "@formepdf/react": "0.10.1"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist/",
    "pkg/",
    "pkg-web/",
    "pkg-node/",
    "scripts/"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/formepdf/forme",
    "directory": "packages/core"
  }
}
