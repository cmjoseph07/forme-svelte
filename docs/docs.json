{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Forme",
  "theme": "mint",
  "logo": {
    "light": "/wordmark.svg",
    "dark": "/wordmark-white.svg"
  },
  "favicon": "/favicon.ico",
  "colors": {
    "primary": "#111827"
  },
  "topbarLinks": [
    {
      "name": "Playground",
      "url": "https://playground.formepdf.com/"
    }
  ],
  "topbarCtaButton": {
    "name": "Get Started",
    "url": "https://github.com/formepdf/forme"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["quickstart", "template-gallery", "vscode", "faq"]
      },
      {
        "group": "Reference",
        "pages": ["components", "styles", "tailwind", "fonts", "page-breaks", "charts", "templates", "embedded-data", "self-hosting"]
      },
      {
        "group": "API Reference",
        "pages": [
          "api-reference/render",
          "api-reference/certify",
          "api-reference/redact",
          "api-reference/merge"
        ]
      },
      {
        "group": "Concepts",
        "pages": [
          "concepts/documents",
          "concepts/credentials",
          "concepts/redaction",
          "concepts/redaction-templates",
          "concepts/digital-certification",
          "concepts/audit-trail"
        ]
      },
      {
        "group": "Enterprise",
        "pages": ["forms", "accessibility", "archival"]
      },
      {
        "group": "SDKs",
        "pages": ["typescript-sdk", "python-sdk", "go-sdk", "rust-sdk"]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/migrating-to-0-9",
          "guides/bring-your-own-ui",
          "migrating-from-react-pdf",
          "replacing-puppeteer"
        ]
      },
      {
        "group": "Changelog",
        "pages": ["changelog/0-9-0", "changelog/0-8-3"]
      }
    ]
  },
  "redirects": [
    { "source": "/api-reference", "destination": "/api-reference/render" },
    { "source": "/digital-signatures", "destination": "/concepts/digital-certification" }
  ]
}
